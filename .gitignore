# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
.venv/
venv/
env/
ENV/

# Python packaging
build/
dist/
*.egg-info/
.eggs/
pip-wheel-metadata/

# =========================
# Jupyter
# =========================
.ipynb_checkpoints/

# =========================
# Environment variables / secrets
# =========================
.env
.env.*
!.env.example

# =========================
# IDE / Editors
# =========================
.idea/
.vscode/
*.swp
*.swo

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Logs
# =========================
*.log
logs/

# =========================
# Databases
# =========================
*.sqlite
*.sqlite3
*.db
*.duckdb

# =========================
# Data files
# =========================
# Raw/private/generated data should not be committed by default.
# Keep small public sample files in data/sample/.

**/data/raw/*
**/data/processed/*
**/data/quarantine/*
**/data/output/*

# Keep directory structure
!**/data/raw/.gitkeep
!**/data/processed/.gitkeep
!**/data/quarantine/.gitkeep
!**/data/output/.gitkeep

# Allow public sample datasets
!**/data/sample/
!**/data/sample/**

# =========================
# Project-specific generated files
# =========================
reports/
exports/
tmp/
temp/